# Create a fine-grained Hugging Face token with:
# "Make calls to Inference Providers"
HF_TOKEN=hf_your_token_here

# LangChain's HF package also checks this name.
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Embedding model for turning your notes and questions into vectors.
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Text-generation model used for the final answer.
# If this model is unavailable on your HF account/provider, try another text-generation model.
HF_LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# "auto" lets Hugging Face choose an available provider.
HF_PROVIDER=auto
