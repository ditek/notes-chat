# Create a Hugging Face token with the permission:
# "Make calls to Inference Providers"
HF_TOKEN=hf_your_token_here

# Embedding model for turning notes and questions into vectors.
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chat model used for the final answer.
HF_LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507

# Hugging Face inference provider.
HF_PROVIDER=nscale

# Local folder used for notes.
NOTES_DIR=notes

# Chroma index location.
# Use:
# - ./chroma_db locally
# - /data/chroma_db in Hugging Face Spaces when a Storage Bucket is mounted at /data.
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=notes

# Public GitHub repo contents endpoint used by `sync-notes`.
NOTES_REPO_CONTENTS_URL=https://api.github.com/repos/ditek/Notes/contents

# Keep false for public deployments.
ENABLE_SIDEBAR_CONTROLS=false
DEFAULT_RETRIEVAL_K=2

# Optional: only needed for non-interactive Hugging Face deploys.
# HF_SPACE_REMOTE_URL=https://huggingface.co/spaces/YOUR_NAMESPACE/YOUR_SPACE
# HF_DEPLOY_USERNAME=YOUR_HF_USERNAME
# The token must have "Write access" permission to the Space repository.
# HF_DEPLOY_TOKEN=hf_your_write_token
